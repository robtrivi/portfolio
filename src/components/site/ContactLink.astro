---
import type { SocialLink } from "@data/resume";
import IconGithub from "~icons/simple-icons/github";
import IconLinkedin from "~icons/simple-icons/linkedin";

interface Props {
  item: SocialLink;
}

const { item } = Astro.props;
const Icon = item.icon === "github" ? IconGithub : IconLinkedin;
---

<div>
  <p
    class="mb-2 text-[10px] font-bold tracking-[0.22em] text-secondary uppercase"
  >
    {item.label}
  </p>
  <a
    href={item.href}
    target="_blank"
    rel="noreferrer"
    class="inline-flex items-center gap-2 text-sm font-bold tracking-[0.16em] text-white uppercase transition hover:text-primary"
  >
    <Icon class="text-base" aria-hidden="true" />
    <span>{item.value}</span>
  </a>
</div>

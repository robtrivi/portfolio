---
import WindowDots from "../ui/WindowDots.astro";

interface NavItem {
  href: string;
  label: string;
}

interface Props {
  session: string;
  status: string;
  timezone: string;
  nav: readonly NavItem[];
}

const { session, status, timezone, nav } = Astro.props;
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-black/80 backdrop-blur-xl"
>
  <div
    class="flex flex-wrap items-center justify-between gap-4 px-4 py-2 md:px-6"
  >
    <div class="flex items-center gap-4">
      <WindowDots />
      <span
        class="text-[9px] font-bold tracking-[0.28em] text-secondary uppercase"
      >
        session: {session}
      </span>
    </div>

    <nav
      class="order-3 w-full overflow-x-auto md:order-2 md:w-auto"
      aria-label="Principal"
    >
      <ul
        class="flex min-w-max items-center gap-5 font-sans text-[11px] tracking-[0.2em] text-secondary uppercase"
      >
        {
          nav.map((item) => (
            <li>
              <a class="transition hover:text-primary" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div
      class="flex items-center gap-4 text-[10px] font-bold tracking-[0.24em] uppercase"
    >
      <div class="flex items-center gap-2">
        <span class="animate-pulse text-primary">{status}</span>
        <div
          class="h-1.5 w-1.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"
        >
        </div>
      </div>
      <span class="text-secondary">{timezone}</span>
    </div>
  </div>
</header>

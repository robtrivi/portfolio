---
interface Props {
  items: readonly string[];
  compact?: boolean;
}

const { items, compact = false } = Astro.props;
---

<ul class="flex flex-wrap gap-2">
  {
    items.map((item) => (
      <li
        class:list={[
          "border border-white/15 bg-white/5 font-sans tracking-[0.18em] text-secondary uppercase",
          compact ? "px-2 py-1 text-[9px]" : "px-3 py-1.5 text-[10px]",
        ]}
      >
        {item}
      </li>
    ))
  }
</ul>

---
import PromptLine from "@components/ui/PromptLine.astro";

interface Props {
  command: string;
  anchorId?: string;
  class?: string;
}

const { command, anchorId, class: className } = Astro.props;
---

<section class:list={["reveal space-y-4", className]}>
  <PromptLine command={command} anchorId={anchorId} />
  <div class="space-y-6">
    <slot />
  </div>
</section>
